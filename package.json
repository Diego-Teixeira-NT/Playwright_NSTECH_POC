{
  "name": "playwright_nstech",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "smoke": "playwright test tests/menus.smoke.spec.ts",
    "smoke:torre": "dotenv -e .env.torre -- playwright test tests/menus.smoke.spec.ts",
    "smoke:danone": "dotenv -e .env.danone -- playwright test tests/menus.smoke.spec.ts",
    "smoke:unilever": "dotenv -e .env.unilever -- playwright test tests/menus.smoke.spec.ts",
    "smoke:boticario": "dotenv -e .env.boticario -- playwright test tests/menus.smoke.spec.ts",
    "smoke:ype": "dotenv -e .env.ype -- playwright test tests/menus.smoke.spec.ts",
    "smoke:minerva": "dotenv -e .env.minerva -- playwright test tests/menus.smoke.spec.ts",
    "smoke:gruposc": "dotenv -e .env.gruposc -- playwright test tests/menus.smoke.spec.ts",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:report": "npm run allure:generate && npm run allure:open"
  },
  "repository": {
    "type": "git",
